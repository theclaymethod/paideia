from __future__ import annotations

import numpy as np

import impl

SEED = 20260101


def test_analytic_anchor():
    # One value you can verify by hand — the cheapest guard against a broken impl.
    # Replace with the real anchor for this chunk.
    assert abs(impl.solve(0) - 0.0) < 1e-9


def test_property_holds_on_novel_inputs():
    rng = np.random.default_rng(SEED)
    for _ in range(50):
        x = float(rng.uniform(-5, 5))
        out = impl.solve(x)
        # Replace with the real invariant(s). Example placeholders:
        assert out >= 0.0                       # e.g. non-negativity
        assert np.isfinite(out)                 # no NaN / inf


def test_invariance_or_second_route():
    rng = np.random.default_rng(SEED + 1)
    for _ in range(30):
        x = float(rng.uniform(-5, 5))
        # Example: an invariance the true answer must obey (edit to fit the chunk).
        assert abs(impl.solve(x) - impl.solve(x)) < 1e-12
